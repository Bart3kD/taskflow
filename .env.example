# Auth
JWT_SECRET=your-long-random-secret-here

# App URL — must be publicly accessible for Telegram webhooks
# Use https://your-domain.com in production, or your ngrok URL for local testing
ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Email (Resend — https://resend.com)
# FROM_EMAIL must use a verified domain. onboarding@resend.dev only works for your own Resend account email.
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAF_your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Admin account created on first run (seed). Changing these after the DB is seeded has no effect.
ADMIN_EMAIL=admin@taskflow.app
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
